# pnpm config
# Pin every dep exactly (matches --save-exact used by the sdk-bump workflow
# and avoids SemVer surprises with our prerelease-tagged @smartspace/api-client).
save-exact=true
auto-install-peers=true
strict-peer-dependencies=false

# TODO: remove shamefully-hoist once phantom-dep usage is cleaned up. Dropping
# it surfaces missing entries in package.json (e.g. types for hast-util-sanitize
# imported transitively via rehype-sanitize). That cleanup belongs in its own PR.
shamefully-hoist=true
