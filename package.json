{
  "name": "@smartspace/source",
  "version": "1.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "env-cmd -f .env concurrently -n TUNNEL,APP \"npm run dev:tunnel\" \"npm run serve\"",
    "serve": "nx serve --open --verbose",
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint smartspace --quiet",
    "lint:all": "nx lint smartspace",
    "lint:fix": "nx lint smartspace --fix",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "prepare": "husky",
    "start:dev": "env-cmd -f .env.dev npm run serve",
    "start:local": "env-cmd -f .env.local npm run serve",
    "start:tunnel": "env-cmd -f .env.local npm run dev:tunnel",
    "start:tunnel:dev": "env-cmd -f .env.dev npm run dev:tunnel",
    "build:dev": "env-cmd -f .env.dev npm run build",
    "build:local": "env-cmd -f .env.local npm run build",
    "test:dev": "env-cmd -f .env.dev npm run test",
    "test:local": "env-cmd -f .env.local npm run test",
    "build:teams": "ts-node teams/build-manifest.ts",
    "dev:tunnel": "node scripts/start-tunnel.js",
    "openapi:fetch": "node scripts/openapi-fetch.mjs",
    "openapi:fetch:dev": "env-cmd -f .env.dev npm run openapi:fetch",
    "openapi:generate": "node scripts/openapi-generate.mjs",
    "openapi:sync": "npm run openapi:fetch && npm run openapi:generate",
    "openapi:sync:dev": "env-cmd -f .env.dev npm run openapi:sync"
  },
  "private": true,
  "dependencies": {
    "@azure/msal-browser": "^3.30.0",
