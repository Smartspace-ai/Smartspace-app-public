{
  "name": "@smartspace/chat-ui",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Reusable chat UI components and ChatService port for SmartSpace clients.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css",
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i src/styles.css -o dist/index.css --minify",
    "prepare": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@jsonforms/core": "^3.7.0",
    "@lobehub/icons-static-svg": "^1.86.0",
    "@jsonforms/react": "^3.7.0",
    "@jsonforms/vanilla-renderers": "^3.7.0",
    "@milkdown/core": "^7.20.0",
    "@milkdown/kit": "7.20.0",
    "@milkdown/plugin-clipboard": "^7.20.0",
    "@milkdown/plugin-listener": "^7.20.0",
    "@milkdown/plugin-slash": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/prose": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@mui/material": "^6.5.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@microsoft/signalr": "^8.0.17",
    "@smartspace/api-client": "*",
    "@tanstack/react-query": "^5.96.2",
    "ace-builds": "^1.43.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-ace": "^14.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^9.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@smartspace/api-client": "0.1.0-main.26012be",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.0",
    "typescript": "5.5.4"
  }
}
