VITE_CLIENT_ID={Entra ID App Client ID}
VITE_CLIENT_AUTHORITY=https://login.microsoftonline.com/{Your Tenant ID}
VITE_CLIENT_SCOPES=api://{Entra ID SmartSpace App Client ID}/smartspaceapi.chat.access
VITE_CHAT_API_URI={Your SmartSpace Chat API URI}

# Tenant GUID. Read by MSAL config and the Teams NAA client as a fallback when
# the authority URL or `window.ssconfig.Tenant_Id` is not set.
VITE_TENANT_ID={Your Entra Tenant ID}

# Teams SSO resource (App ID URI of the Teams app registration). Required when
# you want Teams to issue a token for this resource via NAA / on-behalf-of flows.
VITE_TEAMS_SSO_RESOURCE=api://{Your Teams App Registration App ID URI}

# When true, use MSAL (popup/redirect) in Teams instead of NAA. Required for cross-tenant deployments
# where the Teams SSO resource is not registered. Set to true to always use MSAL flow as if not in Teams.
VITE_TEAMS_USE_MSAL=true